#!/usr/bin/env bash
# figma — lightweight CLI for the Figma REST API + figma-mcp-go plugin bridge
# Version: 0.1.0
# Auth: macOS Keychain (service=figma-cli) with FIGMA_PAT env-var fallback
# Notifications: Hermes-Agent; falls back to $HOME/.local/state/figma-cli/events.log
#
# Subcommands:
#   auth {login|status|logout}
#   files {list|find|current|set|open <key|url>|verify}
#     open:   launch Figma Desktop directly to the file, then plugin open
#     verify: check whether the file is in a paid team or personal Drafts
#   vars  {get|apply <tokens.json>|dump <out.json>}
#   publish [--file <key>]           # Prints instructions (REST has no publish endpoint)
#   devmode [--file <key>]            # Inspects dev resources + meta
#   plugin {install|register-mcp|open|run|status}
#     install:      stage the manifest for Figma Desktop (one-time import)
#     register-mcp: add the MCP server to ~/.mcp.json (Claude Code / Cursor)
#     open:         click Plugins→Development→Figma MCP Go (AppleScript)
#     run:          start the MCP WebSocket server in the foreground
#     status:       probe WS port + manifest
#   hermes {check|notify <msg>}       # Hermes sanity + ad-hoc notify
#   export tokens [--fmt dtcg|css] [--out <file>]
#   doctor                            # Environment self-check
#   permissions                       # macOS privacy permission audit
#   images prep <dir> [--out <d>]     # HEIC→JPG, downscale >4096px, re-encode
#                                     # for clean Finder→Figma drag-and-drop
#   find <query> | --brand .. --category .. --subject ..
#                                     # locate assets via Spotlight (+find fallback),
#                                     # filter by 7-segment filename convention
#
# Failure policy: never leave orphaned state. Every command exits non-zero on
# the first real error. Every action emits a Hermes event (best-effort).

set -Eeuo pipefail

VERSION="0.1.0"
FIGMA_CLI_ROOT="$HOME/scripts/figma-cli"
FIGMA_CLI_LIB="$FIGMA_CLI_ROOT/lib"
FIGMA_CLI_CONFIG="$HOME/.config/figma/cli.toml"
FIGMA_CLI_STATE_DIR="$HOME/.local/state/figma-cli"
FIGMA_CLI_EVENT_LOG="$FIGMA_CLI_STATE_DIR/events.log"

mkdir -p "$(dirname "$FIGMA_CLI_CONFIG")" "$FIGMA_CLI_STATE_DIR"

# Source libraries (each library is self-contained; fail gracefully if missing)
for lib in api keychain hermes files vars onboarding; do
  if [ -f "$FIGMA_CLI_LIB/$lib.sh" ]; then
    # shellcheck disable=SC1090
    . "$FIGMA_CLI_LIB/$lib.sh"
  else
    echo "warn: lib/$lib.sh missing — some commands may fail" >&2
  fi
done

log_event() {
  local level="$1"; shift
  local msg="$*"
  printf '[%s] %s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$level" "$msg" \
    >>"$FIGMA_CLI_EVENT_LOG"
}

die() {
  log_event ERROR "$*"
  echo "error: $*" >&2
  hermes_notify "figma-cli ERROR: $*" || true
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"
}

# Trap uncaught errors so nothing is ever silently dropped
on_err() {
  local code=$?
  log_event ERROR "uncaught exit=$code cmd='$BASH_COMMAND'"
  hermes_notify "figma-cli UNCAUGHT exit=$code: $BASH_COMMAND" || true
  exit "$code"
}
trap on_err ERR

cmd_version() {
  echo "figma-cli $VERSION"
  echo "config:  $FIGMA_CLI_CONFIG"
  echo "events:  $FIGMA_CLI_EVENT_LOG"
}

cmd_doctor() {
  local ok=1
  echo "→ figma-cli doctor"
  for bin in curl jq security gh; do
    if command -v "$bin" >/dev/null 2>&1; then
      echo "  ✓ $bin"
    else
      echo "  ✗ $bin (missing)"; ok=0
    fi
  done
  if keychain_has_pat; then echo "  ✓ Keychain PAT"; else echo "  ○ Keychain PAT (not set; will use \$FIGMA_PAT if present)"; fi
  if [ -n "${FIGMA_PAT:-}" ]; then echo "  ✓ \$FIGMA_PAT env var"; fi
  if [ -f "$FIGMA_CLI_CONFIG" ]; then echo "  ✓ config: $FIGMA_CLI_CONFIG"; else echo "  ○ config not yet written"; fi
  if command -v hermes >/dev/null 2>&1; then
    echo "  ✓ hermes $(hermes --version 2>&1 | head -1)"
  else
    echo "  ○ hermes not on PATH (notifications will log to file only)"
  fi
  [ $ok -eq 1 ] || die "doctor found missing deps"
}

cmd_permissions() {
  # Check all macOS privacy / permission surfaces figx touches.
  echo "→ figx permissions check"
  local all_ok=1

  # 1. Accessibility — required for AppleScript menu navigation
  if osascript -e 'tell application "System Events" to return (UI elements enabled)' 2>/dev/null | grep -qi true; then
    echo "  ✓ Accessibility (System Events UI)"
  else
    echo "  ✗ Accessibility — grant to your terminal in:"
    echo "       System Settings → Privacy & Security → Accessibility"
    all_ok=0
  fi

  # 2. Automation (App-to-App) — attempt a benign AppleScript against Figma
  #    to provoke the permission prompt if not yet granted.
  if pgrep -x Figma >/dev/null 2>&1; then
    if osascript -e 'tell application "Figma" to name' >/dev/null 2>&1; then
      echo "  ✓ Automation (controlling Figma)"
    else
      echo "  ✗ Automation (Figma) — grant to your terminal in:"
      echo "       System Settings → Privacy & Security → Automation → your terminal → Figma ☑"
      all_ok=0
    fi
  else
    echo "  ○ Automation — Figma Desktop not running; skipping probe"
  fi

  # 3. Automation (System Events) — also gated the first time
  if osascript -e 'tell application "System Events" to name' >/dev/null 2>&1; then
    echo "  ✓ Automation (System Events)"
  else
    echo "  ✗ Automation (System Events) — grant in:"
    echo "       System Settings → Privacy & Security → Automation → your terminal → System Events ☑"
    all_ok=0
  fi

  # 4. Keychain access — attempt a non-destructive lookup
  if command -v security >/dev/null 2>&1; then
    if security list-keychains >/dev/null 2>&1; then
      echo "  ✓ Keychain access"
    else
      echo "  ✗ Keychain — unlock login keychain:"
      echo "       security unlock-keychain ~/Library/Keychains/login.keychain-db"
      all_ok=0
    fi
  fi

  # 5. Firewall / outbound — probe api.figma.com
  if curl -sS -o /dev/null -w '%{http_code}' --max-time 5 https://api.figma.com/v1/me | grep -q '^[0-9]'; then
    echo "  ✓ Outbound to api.figma.com"
  else
    echo "  ✗ Outbound blocked — check corporate proxy / firewall"
    all_ok=0
  fi

  # 6. Local loopback — needed for figma-mcp-go WS
  if nc -z 127.0.0.1 1994 2>/dev/null; then
    echo "  ✓ Loopback 127.0.0.1:1994 reachable (figma-mcp-go WS)"
  else
    echo "  ○ Loopback 1994 idle (plugin not running — run 'figx plugin open')"
  fi

  # 7. macOS version
  local macos; macos="$(sw_vers -productVersion 2>/dev/null)"
  echo "  ℹ macOS $macos"

  if [ $all_ok -eq 1 ]; then
    echo "✓ all required permissions granted"
  else
    echo "✗ some permissions missing — fix above, then re-run 'figx permissions'"
    return 1
  fi
}

cmd_auth() {
  local sub="${1:-status}"; shift || true
  case "$sub" in
    login)    keychain_login ;;
    status)   keychain_status ;;
    logout)   keychain_logout ;;
    *) die "auth: unknown subcommand '$sub'" ;;
  esac
}

cmd_files() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list)    files_list "$@" ;;
    find)    files_find "$@" ;;
    current) files_current ;;
    set)     files_set "$@" ;;
    open)    files_open "$@" ;;
    verify)  files_verify "$@" ;;
    mode)
      local msub="${1:-detect}"; shift || true
      case "$msub" in
        detect) mode_detect ;;
        set)    mode_set "$@" ;;
        *) die "files mode: unknown subcommand '$msub' (detect|set)" ;;
      esac
      ;;
    team)
      local tsub="${1:-list}"; shift || true
      case "$tsub" in
        set)     _config_set default_team_id "$1"; echo "✓ default team id: $1" ;;
        current) _config_get default_team_id ;;
        open)    team_open "$@" ;;
        detect)     team_detect ;;
        autodetect) team_autodetect ;;
        ensure-id)  team_ensure_id ;;
        new-project|create-project) team_new_project "$@" ;;
        *) die "files team: unknown subcommand '$tsub' (set|current|open|new-project)" ;;
      esac
      ;;
    project)
      local psub="${1:-list}"; shift || true
      case "$psub" in
        set)
          local arg="${1:-}"; [ -n "$arg" ] || die "usage: figx files project set <id|url>"
          local pid; pid="$(echo "$arg" | sed -n 's|.*/project/\([0-9]*\).*|\1|p')"
          [ -z "$pid" ] && pid="$arg"
          _config_set default_project_id "$pid"
          echo "✓ default project id: $pid"
          ;;
        current) _config_get default_project_id ;;
        list)
          local pid; pid="$(_config_get default_project_id 2>/dev/null)"
          [ -n "$pid" ] || die "no project id — run: figx files project set <id|url>"
          api_get "/v1/projects/$pid/files" | jq -r '.files[] | "\(.key)\t\(.name)"'
          ;;
        open)
          local name="${1:-}"; [ -n "$name" ] || die "usage: figx files project open \"<file name>\""
          local pid; pid="$(_config_get default_project_id 2>/dev/null)"
          [ -n "$pid" ] || die "no project id"
          local key; key="$(api_get "/v1/projects/$pid/files" | jq -r --arg n "$name" '.files[] | select(.name | test($n; "i")) | .key' | head -1)"
          [ -n "$key" ] || die "file '$name' not found in project $pid"
          echo "→ opening $name ($key)"
          files_set "$key" >/dev/null
          files_open "$key"
          ;;
        *) die "files project: unknown subcommand '$psub' (set|current|list|open)" ;;
      esac
      ;;
    *) die "files: unknown subcommand '$sub'" ;;
  esac
}

files_open() {
  # Launch Figma Desktop to a specific file, then run figx plugin open
  # so the agent side is connected without any manual clicking.
  # Accepts either a raw file-key or a full figma.com URL.
  local arg="${1:-}"
  local key
  if [ -z "$arg" ]; then
    key="$(_config_get default_file_key 2>/dev/null)"
  elif echo "$arg" | grep -q 'figma.com/'; then
    key="$(echo "$arg" | sed -n 's|.*figma.com/\(design\|file\|board\)/\([A-Za-z0-9]*\).*|\2|p')"
  else
    key="$arg"
  fi
  [ -n "$key" ] || die "no file key — pass <key|url> or run 'figx files set <key>'"
  echo "→ opening file $key in Figma Desktop"
  open "figma://file/$key"
  sleep 3
  plugin_open
  hermes_notify "figx: opened file $key + plugin dispatched" || true
}

team_open() {
  local team_id="${1:-}"
  [ -n "$team_id" ] || team_id="$(team_ensure_id)"
  [ -n "$team_id" ] || die "no team id available"
  echo "→ opening team $team_id in Figma Desktop"
  open "figma://team/$team_id"
  hermes_notify "figx: opened team $team_id" || true
}

team_new_project() {
  # Create a new project on the currently-viewed team. Two-stage Figma
  # dialog: "이름" (name) input → 계속 (Continue) → [step 2 auto-defaults
  # usually fine]. Works on EN + KO layouts.
  local project_name="${1:-New Project}"
  local team_id="${2:-$(_config_get default_team_id 2>/dev/null)}"
  [ -n "$team_id" ] && { open "figma://team/$team_id"; sleep 1.5; }
  PROJ_NAME_ENV="$project_name" osascript <<'APPLESCRIPT'
set projName to system attribute "PROJ_NAME_ENV"
set plusLabels to {"+ 프로젝트", "+ Project", "+ New project", "+ 새 프로젝트", "프로젝트", "Project", "New project"}
set continueLabels to {"계속", "Continue", "Next", "Create"}

tell application "Figma" to activate
delay 0.6

tell application "System Events"
  tell process "Figma"
    -- 1. Find & click the "+ 프로젝트" button on the team home
    set clickedPlus to false
    try
      set btns to entire contents of window 1
      repeat with el in btns
        try
          set n to name of el
          repeat with lbl in plusLabels
            if n is (lbl as text) then
              click el
              set clickedPlus to true
              exit repeat
            end if
          end repeat
          if clickedPlus then exit repeat
        end try
      end repeat
    end try

    if not clickedPlus then error "Couldn't find '+ 프로젝트' button — are you on the team home page?"
    delay 0.8

    -- 2. Type the project name (focused input by default)
    keystroke projName
    delay 0.3

    -- 3. Click 계속 / Continue
    set clickedCont to false
    try
      set btns2 to entire contents of window 1
      repeat with el in btns2
        try
          set n to name of el
          repeat with lbl in continueLabels
            if n is (lbl as text) then
              click el
              set clickedCont to true
              exit repeat
            end if
          end repeat
          if clickedCont then exit repeat
        end try
      end repeat
    end try
    if not clickedCont then
      -- fallback: press Enter
      key code 36
    end if
    delay 0.8
    -- Step 2 of dialog: accept defaults with Return
    key code 36
    return "✓ project '" & projName & "' created"
  end tell
end tell
APPLESCRIPT
  hermes_notify "figx: new project '$project_name' dispatched" || true
}

team_detect() {
  # Read the Figma Desktop window title to identify the currently-viewed
  # team/file. Outputs the raw title for the user to use.
  osascript <<'APPLESCRIPT' 2>/dev/null
tell application "System Events"
  tell process "Figma"
    try
      return name of front window
    on error
      return ""
    end try
  end tell
end tell
APPLESCRIPT
}

team_autodetect() {
  # Recover the team id via the clipboard. Flow:
  # 1. Ensure Figma Desktop is frontmost on the team home.
  # 2. Trigger Edit → Copy Link or the team URL copy via AppleScript.
  # 3. Read pbpaste, extract /team/<id>/ from figma.com URL, save config.
  # Gracefully falls back to asking the user to paste the URL.
  echo "→ trying to capture current team URL via clipboard"
  local before; before="$(pbpaste 2>/dev/null || echo '')"
  pbcopy </dev/null 2>/dev/null || true    # clear

  osascript <<'APPLESCRIPT' 2>/dev/null || true
tell application "Figma" to activate
delay 0.3
tell application "System Events"
  tell process "Figma"
    -- Common "Copy Link" menu item labels (EN/KO)
    try
      tell menu bar item "Edit" of menu bar 1
        click
        delay 0.2
        tell menu 1
          set mis to name of every menu item
          set labels to {"Copy link", "Copy Link", "링크 복사", "링크 복사하기"}
          repeat with lbl in labels
            if mis contains (lbl as text) then click menu item (lbl as text)
            if mis contains (lbl as text) then exit repeat
          end repeat
        end tell
      end tell
    end try
  end tell
end tell
APPLESCRIPT
  sleep 0.4
  local clip; clip="$(pbpaste 2>/dev/null || echo '')"
  local team_id=""
  if echo "$clip" | grep -q 'figma.com/files/team/'; then
    team_id="$(echo "$clip" | sed -n 's|.*/team/\([A-Za-z0-9]*\)/.*|\1|p')"
  fi
  if [ -z "$team_id" ]; then
    echo "  (couldn't auto-capture — paste your team URL now)"
    echo -n "  URL: "
    read -r url
    team_id="$(echo "$url" | sed -n 's|.*/team/\([A-Za-z0-9]*\)/.*|\1|p')"
  fi
  [ -n "$team_id" ] || die "couldn't extract team id"
  _config_set default_team_id "$team_id"
  echo "✓ team id saved: $team_id"
  [ -n "$before" ] && printf '%s' "$before" | pbcopy
  hermes_notify "figx: team id $team_id saved" || true
}

team_ensure_id() {
  # Used by commands that need a team id. Uses saved config, otherwise
  # triggers autodetect (interactive).
  local id; id="$(_config_get default_team_id 2>/dev/null)"
  if [ -n "$id" ]; then
    echo "$id"
    return 0
  fi
  echo "→ no team id saved; running autodetect" >&2
  team_autodetect >&2
  _config_get default_team_id
}

mode_detect() {
  # Determine whether the frontmost Figma Desktop window is in Dev Mode
  # or Design Mode. Dev Mode toggles the top-right `</>` icon and adds
  # "Code settings / MCP" panels on the right.
  osascript <<'APPLESCRIPT' 2>/dev/null || echo "unknown"
tell application "System Events"
  tell process "Figma"
    try
      set wname to name of front window
      -- "— Dev Mode" / "— 개발 모드" suffix indicates Dev Mode; otherwise Design Mode.
      if wname contains "Dev Mode" or wname contains "개발 모드" then
        return "dev"
      else
        return "design"
      end if
    on error
      return "unknown"
    end try
  end tell
end tell
APPLESCRIPT
}

mode_set() {
  # Toggle to the requested mode (dev|design). Uses the keyboard
  # shortcut Shift+D which Figma bound to 'Toggle dev mode' (locale-
  # independent).
  local want="${1:-}"
  [ -n "$want" ] || die "usage: figx files mode {dev|design}"
  local current; current="$(mode_detect)"
  if [ "$current" = "$want" ]; then
    echo "✓ already in $want mode"
    return 0
  fi
  osascript <<'APPLESCRIPT' >/dev/null 2>&1
tell application "Figma" to activate
delay 0.3
tell application "System Events"
  tell process "Figma"
    keystroke "d" using {shift down}
  end tell
end tell
APPLESCRIPT
  sleep 0.5
  echo "→ switched to $(mode_detect) mode"
}

files_verify() {
  # Verify the resolved file sits in a paid workspace, not free Drafts.
  # GET /v1/files/:key/meta returns role + document_id; from the team/project
  # endpoints we can infer a paid plan. Free drafts have no project/team.
  local key; key="$(files_resolve_key "$@")" || return 2
  echo "→ verifying workspace for file $key"
  local meta; meta="$(api_get "/v1/files/$key/meta" 2>/dev/null || echo '{}')"
  local name; name="$(echo "$meta" | jq -r '.file.name // .name // "?"')"
  local editor; editor="$(echo "$meta" | jq -r '.file.editorType // .editorType // "?"')"
  local role;   role="$(echo "$meta" | jq -r '.file.role // .role // "?"')"
  echo "  name:       $name"
  echo "  editor:     $editor"
  echo "  your role:  $role"
  # Drafts detection: when the endpoint doesn't carry a team/project id
  # the file is personal — Variables multi-mode features are disabled.
  # Figma REST returns team_id=null for Professional files; use folder_name
  # as the reliable signal. Drafts files have folder_name=null or "Drafts".
  local folder; folder="$(echo "$meta" | jq -r '.file.folder_name // .folder_name // ""')"
  if [ -z "$folder" ] || [ "$folder" = "null" ] || [ "$folder" = "Drafts" ]; then
    echo "  ⚠ appears to be a personal Drafts file — move it into a paid team project"
    echo "     otherwise Variables multi-mode (Pep/Cer) and Tokens Studio push may fail."
  else
    echo "  ✓ team-scoped file (project/folder: $folder)"
  fi
  hermes_notify "figx: verified file $key (folder=$folder)" || true
}

cmd_vars() {
  local sub="${1:-get}"; shift || true
  case "$sub" in
    get)     vars_get "$@" ;;
    apply)   vars_apply "$@" ;;
    dump)    vars_dump "$@" ;;
    *) die "vars: unknown subcommand '$sub'" ;;
  esac
}

cmd_publish() {
  local file_key; file_key="$(files_resolve_key "$@")"
  echo "→ Publish is a manual step — the REST API does not expose a publish endpoint."
  echo "  1. Open the file in Figma Desktop: https://www.figma.com/design/$file_key/"
  echo "  2. Click the Assets panel → Publish library"
  echo "  3. Confirm with a commit message"
  hermes_notify "figma-cli: MANUAL publish required for file $file_key" || true
  echo ""
  echo "Waiting for published variables to appear (polling every 15s, Ctrl-C to stop)..."
  local tries=0
  while (( tries < 80 )); do
    if api_get "/v1/files/$file_key/variables/published" | jq -e '.meta.variables | length > 0' >/dev/null 2>&1; then
      echo "✓ Published variables detected"
      hermes_notify "figma-cli: publish detected for $file_key" || true
      return 0
    fi
    sleep 15; tries=$((tries+1))
  done
  die "publish polling timed out after 20 minutes"
}

cmd_devmode() {
  local file_key; file_key="$(files_resolve_key "$@")"
  echo "→ File metadata:"
  api_get "/v1/files/$file_key/meta" | jq '{name, last_modified, editorType, role}' 2>/dev/null || true
  echo ""
  echo "→ Dev resources:"
  api_get "/v1/files/$file_key/dev_resources" 2>/dev/null | jq '.dev_resources // empty' || echo "(none or insufficient scope)"
}

cmd_plugin() {
  local sub="${1:-status}"; shift || true
  case "$sub" in
    install)      plugin_install "$@" ;;
    register-mcp) plugin_register_mcp "$@" ;;
    open)         plugin_open "$@" ;;
    run)          plugin_run "$@" ;;
    status)       plugin_status ;;
    *) die "plugin: unknown subcommand '$sub'" ;;
  esac
}

plugin_install() {
  local src="${1:-$HOME/Projects/figma-mcp-learning/plugins/figma-mcp-go/plugin}"
  [ -f "$src/manifest.json" ] || die "manifest.json not found at $src"
  echo "→ Figma dev plugin manifest: $src/manifest.json"
  if ! pgrep -x Figma >/dev/null 2>&1; then
    open -a Figma 2>/dev/null || die "Figma Desktop not installed"
    sleep 2
  fi
  local script="$FIGMA_CLI_ROOT/tools/auto-import-plugin.applescript"
  if [ -f "$script" ]; then
    echo "→ automating: Plugins → 개발 → 매니페스트에서 플러그인 가져오기…"
    if osascript "$script" "$src/manifest.json"; then
      echo "✓ import sequence dispatched"
      echo "  (if Figma asks for confirmation, accept it)"
    else
      echo "✗ automated import failed — fall back to manual:"
      echo "  Plugins → Development → Import plugin from manifest → $src/manifest.json"
    fi
  else
    echo "  auto-import script missing — do it manually:"
    echo "  Plugins → Development → Import plugin from manifest → $src/manifest.json"
  fi
  hermes_notify "figx: plugin install dispatched ($src/manifest.json)" || true
}

plugin_run() {
  # Start the MCP server on the default ws://127.0.0.1:1994
  if ! command -v npx >/dev/null 2>&1; then die "npx not found"; fi
  echo "→ Starting figma-mcp-go MCP server (ws://127.0.0.1:1994)"
  echo "  Keep Figma Desktop open and run the Figma MCP Go plugin inside it."
  npx -y @vkhanhqui/figma-mcp-go
}

plugin_register_mcp() {
  # Register figma-mcp-go as an MCP server for Claude Code / Cursor / VS Code
  # (~/.mcp.json, JSON) and/or OpenAI Codex CLI (~/.codex/config.toml, TOML).
  # Usage:
  #   figx plugin register-mcp                 # auto: registers everywhere a config exists
  #   figx plugin register-mcp claude          # ~/.mcp.json only
  #   figx plugin register-mcp codex           # ~/.codex/config.toml only
  #   figx plugin register-mcp /custom/.mcp.json   # explicit path
  local target="${1:-auto}"
  local server_name="${FIGX_MCP_NAME:-figma-mcp-go}"

  _reg_claude() {
    local path="${1:-$HOME/.mcp.json}"
    [ -f "$path" ] || echo '{"mcpServers":{}}' >"$path"
    local tmp; tmp="$(mktemp)"
    jq --arg name "$server_name" '
      .mcpServers //= {} |
      .mcpServers[$name] = {
        "command": "npx",
        "args": ["-y", "@vkhanhqui/figma-mcp-go@latest"]
      }
    ' "$path" >"$tmp" && mv "$tmp" "$path"
    echo "✓ Claude/Cursor/VS Code registered in $path"
  }

  _reg_codex() {
    local path="${1:-$HOME/.codex/config.toml}"
    mkdir -p "$(dirname "$path")"
    [ -f "$path" ] || touch "$path"
    # Remove any prior block for this server, then append fresh.
    local tmp; tmp="$(mktemp)"
    awk -v section="[mcp_servers.${server_name}]" '
      BEGIN { skip = 0 }
      {
        if ($0 == section) { skip = 1; next }
        if (skip && /^\[/)  { skip = 0 }
        if (!skip) print
      }
    ' "$path" >"$tmp"
    {
      cat "$tmp"
      echo ""
      echo "[mcp_servers.${server_name}]"
      echo 'command = "npx"'
      echo 'args = ["-y", "@vkhanhqui/figma-mcp-go@latest"]'
    } >"$path"
    rm -f "$tmp"
    echo "✓ Codex CLI registered in $path"
  }

  _reg_opencode() {
    local path="${1:-$HOME/.config/opencode/opencode.json}"
    [ -f "$path" ] || { echo "opencode config not found: $path" >&2; return 1; }
    local tmp; tmp="$(mktemp)"
    jq --arg name "$server_name" '
      .mcp //= {} |
      .mcp[$name] = {
        "type": "local",
        "command": ["npx", "-y", "@vkhanhqui/figma-mcp-go@latest"],
        "enabled": true
      }
    ' "$path" >"$tmp" && mv "$tmp" "$path"
    echo "✓ OpenCode (oh-my-openagent) registered in $path"
  }

  case "$target" in
    auto)
      local acted=0
      _reg_claude "$HOME/.mcp.json" && acted=1
      if [ -d "$HOME/.codex" ]; then
        _reg_codex "$HOME/.codex/config.toml" && acted=1
      fi
      if [ -f "$HOME/.config/opencode/opencode.json" ]; then
        _reg_opencode "$HOME/.config/opencode/opencode.json" && acted=1
      fi
      [ "$acted" = 1 ] || die "no target config found — pass 'claude', 'codex', or 'opencode'"
      ;;
    claude)   _reg_claude   "$HOME/.mcp.json" ;;
    codex)    _reg_codex    "$HOME/.codex/config.toml" ;;
    opencode) _reg_opencode "$HOME/.config/opencode/opencode.json" ;;
    all)
      _reg_claude "$HOME/.mcp.json"
      [ -d "$HOME/.codex" ] && _reg_codex "$HOME/.codex/config.toml"
      [ -f "$HOME/.config/opencode/opencode.json" ] && _reg_opencode "$HOME/.config/opencode/opencode.json"
      ;;
    *.toml) _reg_codex  "$target" ;;
    *.json)
      if [[ "$target" == *opencode* ]]; then _reg_opencode "$target"
      else _reg_claude "$target"; fi ;;
    *) die "unknown target '$target' (use: auto|all|claude|codex|opencode|<path>)" ;;
  esac

  echo "Restart the affected agent (Claude Code / Cursor / VS Code / Codex) to pick up the change."
  hermes_notify "figx: MCP '$server_name' registered ($target)" || true
}

figma_update() {
  if ! pgrep -x Figma >/dev/null 2>&1; then
    open -a Figma 2>/dev/null || die "Figma Desktop not installed"
    sleep 1
  fi
  osascript <<'APPLESCRIPT' || die "could not trigger update check (check Accessibility)"
tell application "Figma" to activate
delay 0.4
tell application "System Events"
  tell process "Figma"
    tell menu bar item "Figma" of menu bar 1
      click
      delay 0.25
      tell menu 1
        set mis to name of every menu item
        set cands to {"Check for updates", "Check for updates…", "업데이트 확인", "업데이트 확인…"}
        repeat with c in cands
          if mis contains (c as text) then
            click menu item (c as text)
            return
          end if
        end repeat
        error "Check-for-updates menu item not found"
      end tell
    end tell
  end tell
end tell
APPLESCRIPT
  echo "✓ Figma update check triggered"
  hermes_notify "figx: Figma update check initiated" || true
}

project_find() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.figx/project.toml" ] || [ -f "$dir/pdp_pipeline/make_pdp.py" ]; then
      echo "$dir"; return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "no figx project found walking up from $PWD" >&2
  return 1
}

project_init() {
  local root="${1:-$PWD}"
  mkdir -p "$root/.figx"
  cat >"$root/.figx/project.toml" <<TOML
# figx per-project config — committed alongside code
name = "$(basename "$root")"
tokens_src = "pdp_pipeline/make_pdp.py"
tokens_out = "design-tokens"
# figma_file_key = "XXXX"
# hermes_webhook = "figma-tokens"
TOML
  echo "✓ $root/.figx/project.toml created"
  echo "  For multi-project context switching, register with Hermes-Agent:"
  echo "    hermes webhook subscribe figx-$(basename "$root") --deliver log"
}

plugin_open() {
  # Launch the already-imported figma-mcp-go plugin inside Figma Desktop.
  # Locale-aware deterministic menu traversal via AppleScript System Events.
  # Handles: Plugins/플러그인/プラグイン/插件, Development/개발/開発/开发.
  if ! pgrep -x Figma >/dev/null 2>&1; then
    die "Figma Desktop not running — open the target file first"
  fi
  local plugin_name="${FIGX_PLUGIN_NAME:-Figma MCP Go}"
  FIGX_PLUGIN_NAME_EXPORT="$plugin_name" osascript <<'APPLESCRIPT' || die "menu click failed (check Accessibility permission for Terminal/iTerm)"
set pluginName to system attribute "FIGX_PLUGIN_NAME_EXPORT"
if pluginName is "" then set pluginName to "Figma MCP Go"

-- Locale candidates. Keep English first for the common case.
set pluginMenuNames to {"Plugins", "플러그인", "プラグイン", "插件", "Plugins & widgets"}
set devMenuNames to {"Development", "개발", "開発", "开发", "개발용", "Dev"}

tell application "Figma" to activate
delay 0.4

tell application "System Events"
  tell process "Figma"
    set topNames to name of every menu bar item of menu bar 1

    -- Locate plugin menu
    set pluginMenu to missing value
    repeat with cand in pluginMenuNames
      if topNames contains (cand as text) then
        set pluginMenu to menu bar item (cand as text) of menu bar 1
        exit repeat
      end if
    end repeat
    if pluginMenu is missing value then
      error "Plugins menu not found — top bar has: " & (topNames as text)
    end if

    click pluginMenu
    delay 0.3

    -- Locate Development submenu
    set devItem to missing value
    tell menu 1 of pluginMenu
      set subNames to name of every menu item
      repeat with cand in devMenuNames
        if subNames contains (cand as text) then
          set devItem to menu item (cand as text)
          exit repeat
        end if
      end repeat
    end tell
    if devItem is missing value then error "Development submenu not found"

    click devItem
    delay 0.3

    -- Click the plugin
    tell menu 1 of devItem
      if (name of every menu item) contains pluginName then
        click menu item pluginName
      else
        error "Plugin '" & pluginName & "' not in Development submenu"
      end if
    end tell
  end tell
end tell
APPLESCRIPT
  echo "✓ Figma MCP Go dispatched"
  sleep 1
  if nc -z 127.0.0.1 1994 2>/dev/null; then
    echo "✓ WS 1994 listening"
  else
    echo "○ WS not yet up — server may still be starting"
  fi
  hermes_notify "figx: Figma MCP Go plugin launched" || true
}

plugin_status() {
  # Probe the websocket port
  if command -v nc >/dev/null 2>&1; then
    if nc -z 127.0.0.1 1994 2>/dev/null; then
      echo "✓ figma-mcp-go WS up on 127.0.0.1:1994"
    else
      echo "○ figma-mcp-go WS not responding on 127.0.0.1:1994"
    fi
  fi
  # Check installed manifest
  local manifest="$HOME/Projects/figma-mcp-learning/plugins/figma-mcp-go/plugin/manifest.json"
  [ -f "$manifest" ] && echo "✓ manifest: $manifest" || echo "○ manifest missing"
}

cmd_hermes() {
  local sub="${1:-check}"; shift || true
  case "$sub" in
    check)  hermes_check ;;
    notify) hermes_notify "$*" ;;
    *) die "hermes: unknown subcommand '$sub'" ;;
  esac
}

cmd_export() {
  local kind="${1:-tokens}"; shift || true
  [ "$kind" = "tokens" ] || die "export: only 'tokens' supported"
  local fmt="dtcg" out=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --fmt) fmt="$2"; shift 2 ;;
      --out) out="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  local file_key; file_key="$(files_resolve_key)"
  local raw; raw="$(api_get "/v1/files/$file_key/variables/local")"
  local json
  case "$fmt" in
    dtcg) json="$(echo "$raw" | jq '.meta')" ;;
    css)  json="$(echo "$raw" | jq -r '
      .meta.variables // {} | to_entries[] |
      "--\(.value.name | gsub("/";"-") | ascii_downcase): \(.value.valuesByMode | to_entries[0].value | tostring);"
    ')" ;;
    *) die "export: unsupported --fmt '$fmt'" ;;
  esac
  if [ -n "$out" ]; then echo "$json" >"$out"; echo "→ wrote $out"; else echo "$json"; fi
}

main() {
  need curl; need jq
  local cmd="${1:-version}"; shift || true
  case "$cmd" in
    version|-v|--version) cmd_version ;;
    doctor)   cmd_doctor ;;
    permissions|perms) cmd_permissions ;;
    figma-update|app-update) figma_update ;;
    project)
      local sub="${1:-find}"; shift || true
      case "$sub" in
        find) project_find ;;
        init) project_init "$@" ;;
        *) die "project: unknown subcommand '$sub' (find|init)" ;;
      esac
      ;;
    onboarding|start|init) onboarding_run ;;
    images)
      local sub="${1:-prep}"; shift || true
      case "$sub" in
        prep) "$FIGMA_CLI_ROOT/tools/image-prep.sh" "$@" ;;
        *) die "images: unknown subcommand '$sub' (prep)" ;;
      esac
      ;;
    assets)
      local sub="${1:-classify}"; shift || true
      case "$sub" in
        classify) python3 "$FIGMA_CLI_ROOT/tools/asset-classify.py" "$@" ;;
        *) die "assets: unknown subcommand '$sub' (classify)" ;;
      esac
      ;;
    find) "$FIGMA_CLI_ROOT/tools/find-assets.sh" "$@" ;;
    auth)     cmd_auth "$@" ;;
    files)    cmd_files "$@" ;;
    vars)     cmd_vars "$@" ;;
    publish)  cmd_publish "$@" ;;
    devmode)  cmd_devmode "$@" ;;
    plugin)   cmd_plugin "$@" ;;
    hermes)   cmd_hermes "$@" ;;
    export)   cmd_export "$@" ;;
    help|-h|--help)
      sed -n '2,30p' "$0" ;;
    *) die "unknown command '$cmd' — try 'figma help'" ;;
  esac
}

main "$@"
